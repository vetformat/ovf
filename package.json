{
  "name": "@vetnote/open-vet-format",
  "version": "1.0.0",
  "description": "FHIR-inspired JSON Schema standard for veterinary medical record exchange",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vetnote/open-vet-format.git"
  },
  "homepage": "https://github.com/vetnote/open-vet-format",
  "keywords": ["veterinary", "fhir", "json-schema", "medical-records", "pet-health", "ovf"],
  "type": "module",
  "main": "schemas/v1/ovf.schema.json",
  "exports": {
    ".": "./schemas/v1/ovf.schema.json",
    "./schemas/v1/*": "./schemas/v1/*"
  },
  "bin": {
    "ovf-validate": "./dist/validate.js"
  },
  "files": ["schemas/", "dist/", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc",
    "validate:schemas": "node --loader ts-node/esm tools/validate-schemas.ts",
    "validate:examples": "node --loader ts-node/esm tools/validate-examples.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run validate:schemas && npm run validate:examples",
    "prepublishOnly": "npm run build && npm run validate && npm run test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
